def impute_size_metrics(row):
    """
    Impute Adjusted Function Points (AFP), Value Adjustment Factor (VAF),
    and Functional Size (UFP) using ISBSG standard relationships.
    
    Rules:
    1. If UFP given, AFP and VAF blank → AFP = UFP, VAF = 1
    2. If UFP and VAF given, AFP blank → AFP = UFP × VAF
    3. If AFP given, UFP and VAF blank → UFP = AFP, VAF = 1
    4. If UFP and AFP given, VAF blank → VAF = AFP / UFP
    5. If all blank → UFP = column mean, AFP = UFP, VAF = 1
    """
    
    ufp = row.get('Functional Size')
    afp = row.get('Adjusted Function Points')
    vaf = row.get('Value Adjustment Factor')
    
    # Rule 1: UFP given, AFP and VAF blank
    if pd.notna(ufp) and pd.isna(afp) and pd.isna(vaf):
        row['Adjusted Function Points'] = ufp
        row['Value Adjustment Factor'] = 1.0
    
    # Rule 2: UFP and VAF given, AFP blank
    elif pd.notna(ufp) and pd.notna(vaf) and pd.isna(afp):
        row['Adjusted Function Points'] = ufp * vaf
    
    # Rule 3: AFP given, UFP and VAF blank
    elif pd.isna(ufp) and pd.notna(afp) and pd.isna(vaf):
        row['Functional Size'] = afp
        row['Value Adjustment Factor'] = 1.0
    
    # Rule 4: UFP and AFP given, VAF blank
    elif pd.notna(ufp) and pd.notna(afp) and pd.isna(vaf):
        if ufp != 0:
            row['Value Adjustment Factor'] = afp / ufp
        else:
            row['Value Adjustment Factor'] = 1.0
    
    # Rule 5: All blank
    elif pd.isna(ufp) and pd.isna(afp) and pd.isna(vaf):
        # Will be handled globally after
        pass
    
    return row

# Apply size metric imputation
data = data.apply(impute_size_metrics, axis=1)

