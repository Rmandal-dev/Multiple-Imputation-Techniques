print("\n" + "-" * 50)
print("STEP 8: Imputing Lines of Code (Language-Specific Conversion)")
print("-" * 50)

def impute_loc(row):
    """Calculate LOC from AFP using language-specific conversion factors."""
    language = row.get('Primary Programming Language')
    afp = row.get('Adjusted Function Points')
    
    if pd.isna(row.get('Lines of Code')) and language in LOC_CONVERSION_FACTORS and pd.notna(afp):
        low, high = LOC_CONVERSION_FACTORS[language]
        conversion_factor = (low + high) / 2
        row['Lines of Code'] = afp * conversion_factor
    
    return row

data = data.apply(impute_loc, axis=1)

