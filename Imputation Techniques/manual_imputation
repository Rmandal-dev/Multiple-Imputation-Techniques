def impute_relative_size(row):
    """Derive Relative Size from Adjusted Function Points using ISBSG bands."""
    afp = row.get('Adjusted Function Points')
    
    if pd.isna(row.get('Relative Size')) and pd.notna(afp):
        if 0 <= afp < 10:
            row['Relative Size'] = 'XXS Extra-extra-small'
        elif 10 <= afp < 30:
            row['Relative Size'] = 'XS Extra-small'
        elif 30 <= afp < 100:
            row['Relative Size'] = 'S Small'
        elif 100 <= afp < 300:
            row['Relative Size'] = 'M1 Medium1'
        elif 300 <= afp < 1000:
            row['Relative Size'] = 'M2 Medium2'
        elif 1000 <= afp < 3000:
            row['Relative Size'] = 'L Large'
        elif 3000 <= afp < 9000:
            row['Relative Size'] = 'XL Extra-large'
        elif 9000 <= afp < 18000:
            row['Relative Size'] = 'XXL Extra-extra-large'
        elif afp >= 18000:
            row['Relative Size'] = 'XXXL Extra-extra-extra-large'
    
    return row

data = data.apply(impute_relative_size, axis=1)

