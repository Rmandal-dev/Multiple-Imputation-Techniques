def impute_effort_metrics(row):
    """
    Impute effort-related metrics including Normalised Work Effort,
    Normalised Work Effort Level 1, and Summary Work Effort.
    """
    
    nwe_l1 = row.get('Normalised Work Effort Level 1')
    nwe = row.get('Normalised Work Effort')
    swe = row.get('Summary Work Effort')
    ufp = row.get('Functional Size')
    
    # If all effort metrics are blank, use mean
    if pd.isna(nwe_l1) and pd.isna(nwe) and pd.isna(swe):
        # Will be handled globally
        pass
    
    # Normalised Level 1 PDR calculation
    if pd.notna(nwe_l1) and pd.notna(ufp) and ufp != 0:
        row['Normalised Level 1 PDR (ufp)'] = nwe_l1 / ufp
    
    # Normalised PDR calculation
    if pd.notna(nwe) and pd.notna(ufp) and ufp != 0:
        row['Normalised PDR (ufp)'] = nwe / ufp
    
    # Pre-2002 PDR calculation
    if pd.notna(swe) and pd.notna(ufp) and ufp != 0:
        row['Pre 2002 PDR'] = swe / ufp
    
    return row

